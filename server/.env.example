PORT=3000
NODE_ENV=production

# MongoDB connection string. The server accepts either MONGODB_URI or the legacy MONGO_URI.
MONGODB_URI=mongodb://127.0.0.1:27017/rescue_mesh
# MONGO_URI=

# Allowed dashboard origin. Use * only if you really need open CORS.
CORS_ORIGIN=*

# Optional map / AI integrations used by the dashboard.
AMAP_API_KEY=
BAIDU_MAP_AK=
DASHSCOPE_API_KEY=
LLM_MODEL=qwen-plus

# Optional toggles.
ENABLE_GEOCACHE=false
ENABLE_ROUTECACHE=false
DEBUG_RESCUE_PLANNER=false
